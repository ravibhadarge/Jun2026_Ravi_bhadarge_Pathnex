---
- name: install docker
  hosts: all
  become: yes
  tasks:
    - name: install docker
      yum:
        name: docker
        state: present
    - name: start and enable docker
      service:       
         name: docker
         state: started
         enable: yes

resource "aws_vpc" "main" 
  cidr_block    = ["10.0.0.0/16"]
}

