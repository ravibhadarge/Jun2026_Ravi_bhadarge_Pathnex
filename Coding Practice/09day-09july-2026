#!/bin/bash
LOAD=$(uptime | awk '{print $10}')

echo "current CPU Load: $LOAD"


pipeline  {
    agent server-dev
    environment  {
        INSTITUTTE_NAME = "ravi"
    }
    stages {
        stage('checkout') {
            steps {
                git url: 'https://github.com/ravibhadarage/sample-java-app.git'
            }
        }
        stage('build')
            steps {
                sh 'mvn clean packege'
            }
         }
         stage('archive') {
             steps {
                archiveArtifacts artifacts: 'target/*.jar', fingerprint: true
             }
         }
     }
 }


stages:
  - build

build:
  stage: build
  image: maven:3.8.1-jdk-21 

  script:
    - git clone https://github.com/ravi/sample-java-app.git
    - cd sample-java-app
    - mvn clean package 

  artifacts:
    paths: 
      - target/*.jar
    expire_in: 1 week



