---
- name: setup docker for nginx
  hosts: server-prod
  become: yes
  tasks:
    - name: pull nginx image
      docker_image:  
         name: nginx
         source: pull
    - name: run the nginx container
      docker_container:
          name: nginx-container
          image: nginx
          state: started
          published_ports:
              - "8080:80"

resource  "aws_launch_configuratoin" "example" {
  name          = "example-config"
  image_id      = "ami-0abcd2345abcd1234"
  instance_type = "m7.4xlarge"
}
resource "aws_autoscaling_group" "prod-asg" {
  desired_capacity           = 2
  max_size                   = 3
  min_size                   = 1
  vpc_zone_identifier        = ["subnet-123456789" ]
  launch_configuration       = aws_launch_configuration.prod-asg.id
}


apiVersion: apps/v1
kind: Deployment
metadata:
  name:  prod-deployment
spec:
  replicas: 1 
  selector:
    matchLabels:
      app: ravi-app
  template: 
    spec: 
      containers:
        - name: nginx
          image: nginx
          ports: 
            - containerPorts: 80

---
apiVersion: autoscaling/v2

kind: HorizontalPodAutoscalar
metadata: 
  name: ravi-hpa
spec:
  scaleTargetRef
    apiVersion: apps/v1
    kind: Deployment
    name: ravi-deployment
  minReplicas: 1
  maxReplicas: 5
  targetCPUUtilazationPercentage: 50


pipeline  {
     agent dev-server
     stages {
         steps('deploy to kubernate')
            steps {
               script {
                  sh 'kubectl apply -f deployment.yml'
                }
            }
        }
    }
}  


stages:
  - deploy
 
deploy:
  stage: deploy
  script:
    - kubectl apply -f kubernates/deployment.yml







