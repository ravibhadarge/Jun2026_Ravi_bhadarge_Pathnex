         shell: /bin/bash
    


provider  "aws" {
  region = "us-south-1"
}

resource "aws_security_group" "raviSG" {
  name               = "raviSG"
  description        =  "ravi SG for SSH"
   
  ingress  {
     from_port       = 22
     to_port         = 22
     protocol        = "tcp" 
     cidr_block      = ["0.0.0.0/0"]
   }
}


resource  "aws_instance" "raviEC2"
  ami                    = "ami-abcd1234abcd12345"
  instance_type          = "r61.4xlarge"
  vpc_security_group_ids = [aws_security_group.raviSG.id]

  tags = {
   name= "ravi-EC2"
  }
}

